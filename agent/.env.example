# ── network ───────────────────────────────────────────────────────────────
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337                  # 31337 = local anvil, 84532 = base sepolia

# ── contracts (filled in after deploy) ─────────────────────────────────────
ESCROW_ADDRESS=0x...           # the token address is read from the escrow

# ── role keys (each process needs only its own) ────────────────────────────
# Buyer (Agent A). On local anvil this is account #1.
AGENT_A_PK=0x...
# Worker. On local anvil this is account #2. In a hosted deployment the agent host holds this.
HERMES_PK=0x...
HERMES_NAME=hermes-local

# ── amounts (whole ag3nt) ──────────────────────────────────────────────────
PAYMENT=100
BOND=10
